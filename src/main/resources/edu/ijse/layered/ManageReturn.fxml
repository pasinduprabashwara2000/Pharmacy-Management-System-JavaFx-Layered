<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="681.0" prefWidth="1093.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ijse.layered.controller.ReturnController">

    <children>

        <!-- Order -->
        <Label layoutX="31.0" layoutY="20.0" prefHeight="38.0" prefWidth="165.0" text="Order :">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <ComboBox fx:id="cmbOrder" layoutX="191.0" layoutY="20.0" prefHeight="38.0" prefWidth="320.0" promptText="Select Order" />

        <!-- Customer -->
        <Label layoutX="31.0" layoutY="85.0" prefHeight="38.0" prefWidth="165.0" text="Customer :">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <ComboBox fx:id="cmbCustomer" layoutX="191.0" layoutY="85.0" prefHeight="38.0" prefWidth="320.0" promptText="Select Customer" />

        <!-- Return Date -->
        <Label layoutX="600.0" layoutY="20.0" prefHeight="38.0" prefWidth="165.0" text="Return Date :">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <DatePicker fx:id="datePickerReturn" layoutX="770.0" layoutY="20.0" prefHeight="38.0" prefWidth="280.0" />

        <!-- Total Refund -->
        <Label layoutX="600.0" layoutY="85.0" prefHeight="38.0" prefWidth="165.0" text="Total Refund :">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TextField fx:id="txtTotalRefund" layoutX="770.0" layoutY="85.0" prefHeight="38.0" prefWidth="280.0" promptText="Enter Refund Amount" />

        <!-- Buttons -->
        <Button fx:id="btnSave" layoutX="32.0" layoutY="164.0" mnemonicParsing="false" onAction="#handleSave" prefHeight="38.0" prefWidth="120.0" styleClass="save-btn" text="Save" />

        <Button fx:id="btnUpdate" layoutX="171.0" layoutY="164.0" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="38.0" prefWidth="120.0" styleClass="update-btn" text="Update" />

        <Button fx:id="btnDelete" layoutX="314.0" layoutY="164.0" mnemonicParsing="false" onAction="#handleDelete" prefHeight="38.0" prefWidth="120.0" styleClass="delete-btn" text="Delete" />

        <Button fx:id="btnReset" layoutX="457.0" layoutY="164.0" mnemonicParsing="false" onAction="#handleReset" prefHeight="38.0" prefWidth="120.0" styleClass="reset-btn" text="Reset" />

        <!-- Table -->
        <TableView fx:id="tblReturns" layoutX="32.0" layoutY="242.0" prefHeight="413.0" prefWidth="1009.0">

            <columns>

                <TableColumn fx:id="colReturnId" prefWidth="120.0" text="Return ID" />

                <TableColumn fx:id="colOrderId" prefWidth="180.0" text="Order ID" />

                <TableColumn fx:id="colCustomerId" prefWidth="180.0" text="Customer ID" />

                <TableColumn fx:id="colReturnDate" prefWidth="220.0" text="Return Date" />

                <TableColumn fx:id="colTotalRefund" prefWidth="309.0" text="Total Refund" />

            </columns>

        </TableView>

    </children>

</AnchorPane>
