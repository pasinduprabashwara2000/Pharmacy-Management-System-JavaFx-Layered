<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="681.0" prefWidth="1093.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.ijse.layered.controller.DashboardController">
    <children>

        <!-- ══════════════════════════════════════
             STAT CARDS  (GridPane — 4 equal fixed columns)
             Each column = (1009 - 3×20 gap) / 4 = 237.25 → 237
             ══════════════════════════════════════ -->
        <GridPane hgap="20.0" layoutX="33.0" layoutY="39.0" vgap="0.0">
            <columnConstraints>
                <ColumnConstraints maxWidth="237.0" minWidth="237.0" prefWidth="237.0" />
                <ColumnConstraints maxWidth="237.0" minWidth="237.0" prefWidth="237.0" />
                <ColumnConstraints maxWidth="237.0" minWidth="237.0" prefWidth="237.0" />
                <ColumnConstraints maxWidth="237.0" minWidth="237.0" prefWidth="237.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="120.0" minHeight="120.0" prefHeight="120.0" />
            </rowConstraints>

            <!-- Card 1 — Total Medicines -->
            <VBox prefHeight="151.0" prefWidth="221.0" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <GridPane.margin><Insets right="0.0" /></GridPane.margin>
                <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
                <Label styleClass="stat-card-icon" text="💊" />
                <Label fx:id="lblTotalMedicines" styleClass="stat-card-value" text="0" />
                <Label styleClass="stat-card-label" text="Total Medicines" />
            </VBox>

            <!-- Card 2 — Total Customers -->
            <VBox prefHeight="151.0" prefWidth="240.0" styleClass="stat-card" GridPane.columnIndex="1">
                <GridPane.margin><Insets left="20.0" /></GridPane.margin>
                <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
                <Label styleClass="stat-card-icon" text="👥" />
                <Label fx:id="lblTotalCustomers" styleClass="stat-card-value" text="0" />
                <Label styleClass="stat-card-label" text="Total Customers" />
            </VBox>

            <!-- Card 3 — Low Stock Alerts -->
            <VBox prefHeight="120.0" prefWidth="237.0" styleClass="stat-card" stylesheets="@css/style.css" GridPane.columnIndex="2">
                <GridPane.margin><Insets left="20.0" /></GridPane.margin>
                <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
                <Label styleClass="stat-card-icon" text="⚠️" />
                <Label fx:id="lblLowStock" styleClass="stat-card-value stat-card-value-danger" text="0" />
                <Label styleClass="stat-card-label" text="Low Stock Alerts" />
            </VBox>

            <!-- Card 4 — Today's Orders -->
            <VBox prefHeight="120.0" prefWidth="237.0" styleClass="stat-card" stylesheets="@css/style.css" GridPane.columnIndex="3">
                <GridPane.margin><Insets left="20.0" /></GridPane.margin>
                <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
                <Label styleClass="stat-card-icon" text="🛒" />
                <Label fx:id="lblTodaysOrders" styleClass="stat-card-value stat-card-value-info" text="0" />
                <Label styleClass="stat-card-label" text="Today's Orders" />
            </VBox>

        </GridPane>

        <!-- ══════════════════════════════════════
             RECENT ORDERS SECTION
             ══════════════════════════════════════ -->
        <Label layoutX="32.0" layoutY="240.0" styleClass="dashboard-section-title" text="Recent Orders">
            <font><Font size="16.0" /></font>
        </Label>

        <TableView fx:id="tblRecentOrders" layoutX="32.0" layoutY="272.0" prefHeight="381.0" prefWidth="1009.0">
            <columns>
                <TableColumn fx:id="colOrderId" prefWidth="130.0" text="Order ID" />
                <TableColumn fx:id="colCustomerName" prefWidth="230.0" text="Customer" />
                <TableColumn fx:id="colMedicineName" prefWidth="230.0" text="Medicine" />
                <TableColumn fx:id="colQty" prefWidth="100.0" text="Qty" />
                <TableColumn fx:id="colTotalPrice" prefWidth="160.0" text="Total Price" />
                <TableColumn fx:id="colOrderDate" prefWidth="159.0" text="Order Date" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
